{
	"name": "mgsbot",
	"description": "Conversational Telegram bot with long-term memory, emergent personality, and multi-modal capabilities",
	"version": "1.0.39",
	"author": "Mio Gato Software",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/eliaquin/mgsbot.git"
	},
	"keywords": [
		"telegram",
		"bot",
		"ai",
		"gemini",
		"conversational",
		"memory",
		"personality",
		"grammy",
		"bun"
	],
	"module": "index.ts",
	"dependencies": {
		"@elevenlabs/elevenlabs-js": "^2.44.0",
		"@google/genai": "^1.50.1",
		"dayjs": "^1.11.20",
		"grammy": "^1.42.0",
		"openai": "^6.34.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@types/bun": "1.3.13"
	},
	"private": true,
	"scripts": {
		"start": "bun run index.ts",
		"dev": "bun --watch run index.ts",
		"profile:init": "bun run index.ts --init-profile",
		"profile:show": "bun run index.ts --show-profile",
		"profile:sync": "bun run index.ts --sync-profile",
		"rules:init": "bun run index.ts --init-rules",
		"rules:show": "bun run index.ts --show-rules",
		"test": "bun test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"build": "bun build --compile --minify index.ts --outfile mgsbot",
		"build:linux": "bun build --compile --minify --target=bun-linux-x64 index.ts --outfile mgsbot",
		"release:patch": "bun pm version patch -m 'chore: bump version to v%s' && git push origin main --tags",
		"release:minor": "bun pm version minor -m 'chore: bump version to v%s' && git push origin main --tags",
		"release:major": "bun pm version major -m 'chore: bump version to v%s' && git push origin main --tags"
	},
	"type": "module"
}

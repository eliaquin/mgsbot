# ===================================
# Required
# ===================================

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=

# ===================================
# Chat Provider Configuration
# ===================================

# Chat provider to use: "gemini" (default), "openrouter", "anthropic",
# "azure", "alibaba", "fireworks", "openai", "deepseek", or "fal".
# This only controls conversation text. STT, TTS, and image generation are
# configured separately below.
CHAT_PROVIDER=gemini

# Google GenAI API Key (required for the full bot experience, even when chat
# uses a different provider). Used for embeddings, Gemini STT, fallback image
# analysis, YouTube analysis, and Gemini image generation.
GOOGLE_API_KEY=

# Gemini model (optional, default: gemini-3-flash-preview)
GEMINI_MODEL=gemini-3-flash-preview

# OpenRouter API Key (required if CHAT_PROVIDER=openrouter)
OPENROUTER_API_KEY=

# OpenRouter model (optional, default: anthropic/claude-3.5-sonnet)
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Anthropic API Key (required if CHAT_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Anthropic model (optional, default: claude-sonnet-4-5-20250929)
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Azure API Key (required if CHAT_PROVIDER=azure)
AZURE_API_KEY=

# Azure endpoint URL (required if CHAT_PROVIDER=azure)
AZURE_ENDPOINT=https://your-resource.openai.azure.com/openai/v1/chat/completions

# Azure model (optional, default: Kimi-K2.5)
AZURE_MODEL=Kimi-K2.5

# DashScope API Key (required if CHAT_PROVIDER=alibaba)
DASHSCOPE_API_KEY=

# DashScope model (optional, default: qwen3.5-plus)
DASHSCOPE_MODEL=qwen3.5-plus

# Fireworks API Key (required if CHAT_PROVIDER=fireworks)
FIREWORKS_API_KEY=

# Fireworks model (optional, default: accounts/fireworks/models/glm-5)
FIREWORKS_MODEL=accounts/fireworks/models/glm-5

# OpenAI API Key (required if CHAT_PROVIDER=openai)
OPENAI_API_KEY=

# OpenAI model (optional, default: gpt-5.4)
OPENAI_MODEL=gpt-5.4

# DeepSeek API Key (required if CHAT_PROVIDER=deepseek)
DEEPSEEK_API_KEY=

# DeepSeek model (optional, default: deepseek-v4-pro)
DEEPSEEK_MODEL=deepseek-v4-pro

# fal.ai API Key (required if CHAT_PROVIDER=fal, IMAGE_PROVIDER=fal,
# STT_PROVIDER=fal, or TTS_PROVIDER=fal)
FAL_API_KEY=

# fal.ai chat model (optional, default: google/gemini-2.5-pro)
FAL_MODEL=google/gemini-2.5-pro

# ===================================
# Access Control
# ===================================

# Telegram group ID allowed to use the bot
ALLOWED_GROUP_ID=

# Telegram user ID of the bot owner
OWNER_USER_ID=

# ===================================
# Optional Services
# ===================================

# LemonFox API Key (for TTS voice responses and audio transcription)
LEMON_FOX_API_KEY=

# Speech-to-text provider: "gemini", "fal", or "lemonfox".
# When unset, falls back in order: gemini -> fal -> lemonfox (first with a key wins).
# STT_PROVIDER=gemini

# ElevenLabs API Key (for high-quality TTS voice responses)
ELEVENLABS_API_KEY=

# ElevenLabs Voice ID (browse voices at elevenlabs.io/app/voice-library)
ELEVENLABS_VOICE_ID=

# Inworld API Key + voice ID (for TTS voice responses)
INWORLD_API_KEY=
INWORLD_VOICE_ID=

# TTS provider: "elevenlabs", "inworld", "lemonfox", or "fal".
# When unset, auto-detects in order: elevenlabs -> inworld -> lemonfox.
# fal requires TTS_PROVIDER=fal explicitly.
# TTS_PROVIDER=elevenlabs

# fal.ai voice for TTS_PROVIDER=fal (Aria, Roger, Sarah, Charlotte, Rachel)
FAL_VOICE=Sarah

# Image generation provider: "gemini" (default) or "fal".
# IMAGE_PROVIDER=gemini
# fal.ai image model: "gpt-image-2" (default) or "nano-banana-pro".
# FAL_IMAGE_MODEL=gpt-image-2

# ===================================
# Timezone
# ===================================

# IANA timezone for the bot (affects sleep schedule, time awareness, follow-ups)
# Default: America/Santo_Domingo
# BOT_TIMEZONE=America/Santo_Domingo

# ===================================
# Bot Mode
# ===================================

# Set to "true" to enable simple assistant mode
# When enabled: no image generation, no audio processing, no YouTube analysis
# Uses a basic "You are a helpful assistant" prompt instead of personality
SIMPLE_ASSISTANT_MODE=false

# Set to "true" to enable English tutor mode
# Adds a natural English-practice persona and forces STT to transcribe as English.
# Does not change image behavior.
ENABLE_TUTOR_MODE=false

# Set to "true" to remove image-generation limits
# Bypasses the weekly schedule, enables on-demand [IMAGE: ...] (subject-only) and
# [IMAGE_SELF: ...] (self-in-scene) markers, and allows baseless generation (fal.ai).
# Independent of tutor mode; does not affect language or STT.
FULL_ACCESS_MODE=false

# ===================================
# Proactive Features
# ===================================

# Set to "true" to enable proactive follow-ups in DMs
# Bot will ask about plans/events the user mentioned (e.g., "how was the movie?")
ENABLE_FOLLOW_UPS=false

# Set to "true" to enable proactive check-in messages in DMs
# Bot will reach out ~2 times/week to chat, like a real friend
ENABLE_CHECK_INS=false
# CHECK_INS_PER_WEEK=2

# Set to "true" to enable conversation logging to daily text files (logs/ folder)
ENABLE_CHAT_LOG=false

# ===================================
# Development
# ===================================

# Set to "development" for verbose logging
NODE_ENV=production
